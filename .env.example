# OpenRouter — swap OPENROUTER_MODEL value to change LLM instantly, no code changes
OPENROUTER_API_KEY=
# Model examples: anthropic/claude-sonnet-4-5, openai/gpt-4o, google/gemini-pro-1.5
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Google Drive — OAuth2 (run scripts/get_oauth_token.py once to get these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# GHL
GHL_WEBHOOK_SECRET=eviction-command-secret-2024
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PENDING_REVIEW_STAGE_ID=

# Service
PORT=8000
ENVIRONMENT=production
